# but ignore them in src/main/resources/wasm/ if accidentally copied
src/main/resources/wasm/*.wasm

# Generated resources
src/generated/

# Temporary files
*.tmp
*.bak
*.swp
*.swo
*~

# Log files
*.log

# JVM crash logs
hs_err_pid*
replay_pid*

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Keep gradle wrapper jar
!gradle/wrapper/*.jar

# Keep jarJar dependencies if needed
!**/libs/*.jar
