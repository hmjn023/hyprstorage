{
  "name": "hyperstorage",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint:kotlin": "./gradlew ktlintCheck",
    "format:kotlin": "./gradlew ktlintFormat",
    "test:kotlin": "./gradlew test",
    "build:kotlin": "./gradlew build",
    "lint:rust": "cd src/main/rust && cargo clippy",
    "format:rust": "cd src/main/rust && cargo fmt",
    "test:rust": "cd src/main/rust && cargo test",
    "build:rust": "cd src/main/rust && cargo build --target wasm32-unknown-unknown --release",
    "lint:all": "npm run lint:kotlin && npm run lint:rust",
    "format:all": "npm run format:kotlin && npm run format:rust",
    "test:all": "npm run test:kotlin && npm run test:rust",
    "build:all": "npm run build:kotlin && npm run build:rust",
    "prepare": "husky"
  },
  "keywords": [],
